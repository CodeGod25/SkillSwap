# SkillSwap Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# Backend API URL
# Local development: http://localhost:5000
# Production: Your Vercel backend URL
NEXT_PUBLIC_API_BASE=http://localhost:5000

# ============================================
# PRODUCTION DEPLOYMENT NOTES:
# ============================================
#
# For Vercel deployment:
# 1. Add this variable in Vercel Dashboard → Settings → Environment Variables
# 2. NEXT_PUBLIC_API_BASE: Set to your deployed backend URL
#    Example: https://skillswap-api.vercel.app
# 3. All environment variables for Next.js must start with NEXT_PUBLIC_
#    to be accessible in the browser
# 4. Redeploy frontend after updating environment variables
